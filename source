    local TopBar, tabContainer = CreateTopBar(MainFrame)
    TabContainer = tabContainer
    local ContentFrame, subTabContainer = CreateContentContainer(MainFrame)
    SubTabContainer = subTabContainer
    ColumnsFrame, Columns = CreateColumnContainer(ContentFrame)
    
    if syn and syn.protect_gui then
        syn.protect_gui(ScreenGui)
    end
    ScreenGui.Parent = CoreGui
    return {
        ScreenGui = ScreenGui,
        MainFrame = MainFrame,
        TabContainer = TabContainer,
        SubTabContainer = SubTabContainer,
        ColumnsFrame = ColumnsFrame,
        Columns = Columns
    }
end
