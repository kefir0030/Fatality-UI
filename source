local function CreateTab(parent, name, isActive, onClick)
    local Tab = Instance.new("TextButton")
    Tab.Name = name
    local TextService = game:GetService("TextService")
    local textSize = TextService:GetTextSize(name, 16, Enum.Font.GothamBold, Vector2.new(1000, 38))
    local tabWidth = textSize.X + 20
    Tab.Size = UDim2.new(0, tabWidth, 0, 38)
    Tab.BackgroundTransparency = 1
    Tab.Text = name
    Tab.Font = Enum.Font.GothamBold
    Tab.TextSize = 16
    Tab.TextColor3 = isActive and Color3.fromRGB(255, 255, 255) or Config.Theme.TextColor    Tab.Parent = parent
    local Underline = Instance.new("Frame")
    Underline.Name = "Underline"
    Underline.Size = UDim2.new(1, 0, 0, 3)
    Underline.Position = UDim2.new(0, 0, 1, -5)
    Underline.BackgroundColor3 = Config.Theme.Primary
    Underline.BorderSizePixel = 0
    Underline.Visible = isActive
    Underline.Parent = Tab
    Tab.MouseButton1Click:Connect(function()
        if onClick then
            onClick(name, Tab, Underline)
        end
    end)
    Tab.MouseEnter:Connect(function()
        if not Underline.Visible then
            TweenService:Create(Tab, TweenInfo.new(0.2), {
                TextColor3 = Color3.fromRGB(220, 220, 220)
            }):Play()
        end
    end)
    Tab.MouseLeave:Connect(function()
        if not Underline.Visible then
            TweenService:Create(Tab, TweenInfo.new(0.2), {
                TextColor3 = Config.Theme.TextColor
            }):Play()
        end
    end)
    AllTabs[name] = {Button = Tab, Underline = Underline}
    return Tab
end
