    Label.TextXAlignment = Enum.TextXAlignment.Left    Label.Parent = CheckboxFrame
    local BindButton
    if bindKey then
        BindButton = Instance.new("TextButton")
        BindButton.Name = "BindKey"
        BindButton.Size = UDim2.new(0, 45, 0, 18)
        BindButton.Position = UDim2.new(1, -29, 0.5, -9)
        BindButton.BackgroundColor3 = Color3.fromRGB(40, 35, 60)
        BindButton.BorderSizePixel = 1
        BindButton.BorderColor3 = Color3.fromRGB(60, 50, 90)
        BindButton.Text = bindKey
        BindButton.Font = Enum.Font.GothamBold
        BindButton.TextSize = 9
        BindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        BindButton.Parent = CheckboxFrame
        local isBinding = false
        local currentBind = bindKey
        local function RegisterBind(keyName)
            if currentBind and currentBind ~= "NONE" and BindRegistry[currentBind] then
                for i, data in ipairs(BindRegistry[currentBind]) do
                    if data.checkbox == Checkbox then
                        table.remove(BindRegistry[currentBind], i)
                        break
                    end
                end
            end
            if keyName and keyName ~= "NONE" then
                if not BindRegistry[keyName] then
                    BindRegistry[keyName] = {}
                end
                table.insert(BindRegistry[keyName], {
                    checkbox = Checkbox,
                    toggle = function()
                        isChecked = not isChecked
                        CheckMark.Visible = isChecked
                        ElementStates[stateKey] = isChecked
                        TweenService:Create(Checkbox, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                            BackgroundColor3 = isChecked and Config.Theme.Primary or Color3.fromRGB(40, 35, 60)
                        }):Play()
                    end
                })
            end
        end
        RegisterBind(currentBind)
        BindButton.MouseButton1Click:Connect(function()
            if not isBinding then
                isBinding = true
                BindButton.Text = "..."
                BindButton.TextColor3 = Config.Theme.Primary
                local connection
                connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == Enum.KeyCode.Escape then
                            currentBind = "NONE"
                            BindButton.Text = "NONE"
                            BindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                            isBinding = false
                            RegisterBind(currentBind)
                            connection:Disconnect()
                        elseif not gameProcessed then
                            local keyName = input.KeyCode.Name
                            currentBind = keyName
                            BindButton.Text = keyName
                            BindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                            isBinding = false
                            RegisterBind(currentBind)
                            connection:Disconnect()
                        end
                    end
                end)
            end
        end)
    end
    
    local isChecked = ElementStates[stateKey]
    if isChecked == nil then
        isChecked = defaultValue or false
        ElementStates[stateKey] = isChecked
    end
    
    CheckMark.Visible = isChecked
    Checkbox.BackgroundColor3 = isChecked and Config.Theme.Primary or Color3.fromRGB(40, 35, 60)
    
    Checkbox.MouseButton1Click:Connect(function()
        isChecked = not isChecked
        CheckMark.Visible = isChecked
        ElementStates[stateKey] = isChecked
        local tween = TweenService:Create(Checkbox, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundColor3 = isChecked and Config.Theme.Primary or Color3.fromRGB(40, 35, 60)
        })
        tween:Play()
    end)
    return CheckboxFrame
end
