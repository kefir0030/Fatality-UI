    local function UpdateSubTabs()
        for _, child in ipairs(SubTabContainer:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        AllSubTabs = {}
        local subTabs = tabSubTabs[CurrentTab] or {}
        for i, subTabName in ipairs(subTabs) do
            CreateSubTab(SubTabContainer, subTabName, i == 1, SwitchSubTab)
        end
        if #subTabs > 0 then
            CurrentSubTab = subTabs[1]
        end
    end
    local function SwitchTab(tabName)
        CurrentTab = tabName
        for name, data in pairs(AllTabs) do
            local isActive = name == tabName
            data.Underline.Visible = isActive
            TweenService:Create(data.Button, TweenInfo.new(0.2), {
                TextColor3 = isActive and Color3.fromRGB(255, 255, 255) or Config.Theme.TextColor
            }):Play()
        end
        UpdateSubTabs()
        if tabName == "RAGE" then
            LoadRageContent()
        elseif tabName == "VISUALS" then
            LoadVisualsContent()
        elseif tabName == "MISC" then
            LoadMiscContent()
        elseif tabName == "INVENTORY" then
            LoadInventoryContent()
        elseif tabName == "LEGIT" then
            LoadLegitContent()
        end
    end
    for i, tabName in ipairs(tabs) do
        CreateTab(TabContainer, tabName, i == 1, SwitchTab)
    end
